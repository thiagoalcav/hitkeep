{
    "name": "@hitkeep/dashboard",
    "license": "MIT",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build && npm run sync:public",
        "sync:public": "node scripts/sync-public.mjs",
        "transloco:optimize": "transloco-optimize dist/dashboard/browser/i18n",
        "build:tracker": "esbuild src/tracker/index.ts --bundle --minify --outfile=dist/dashboard/browser/hk.js && esbuild src/tracker/vitals.ts --bundle --minify --outfile=dist/dashboard/browser/hk-vitals.js",
        "build:prod": "ng build --configuration production && npm run transloco:optimize && npm run build:tracker && npm run sync:public",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "test:ci": "ng test --watch=false --no-progress",
        "i18n:check": "node scripts/check-i18n-locales.mjs",
        "e2e": "node scripts/run-e2e.mjs",
        "lint": "ng lint",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^22.0.2",
        "@angular/cdk": "~22.0.2",
        "@angular/common": "^22.0.2",
        "@angular/compiler": "^22.0.2",
        "@angular/core": "^22.0.2",
        "@angular/forms": "^22.0.2",
        "@angular/platform-browser": "^22.0.2",
        "@angular/router": "^22.0.2",
        "@fontsource-variable/lexend": "^5.2.11",
        "@jsverse/transloco-locale": "^8.4.0",
        "@primeuix/themes": "^2.0.3",
        "@scalar/api-reference": "^1.61.0",
        "@tailwindcss/postcss": "^4.3.1",
        "chart.js": "^4.5.1",
        "circle-flags": "^2.8.3",
        "primeicons": "^7.0.0",
        "primeng": "^21.1.9",
        "qr-code-styling": "^1.9.2",
        "rxjs": "~7.8.2",
        "tailwindcss": "^4.3.1",
        "tailwindcss-primeui": "^0.6.1",
        "tslib": "^2.8.1",
        "web-vitals": "^5.3.0"
    },
    "devDependencies": {
        "@angular-eslint/builder": "^22.0.0",
        "@angular/build": "^22.0.4",
        "@angular/cli": "^22.0.4",
        "@angular/compiler-cli": "^22.0.2",
        "@eslint/js": "^10.0.1",
        "@jsverse/transloco": "^8.4.0",
        "@jsverse/transloco-optimize": "^8.4.0",
        "@playwright/test": "^1.61.1",
        "@types/jasmine": "~6.0.0",
        "@vitest/browser-playwright": "^4.1.9",
        "@vitest/coverage-v8": "^4.1.9",
        "angular-eslint": "22.0.0",
        "baseline-browser-mapping": "^2.10.38",
        "eslint": "^10.5.0",
        "jasmine-core": "~6.3.0",
        "jsdom": "^29.1.1",
        "oxfmt": "^0.56.0",
        "playwright": "^1.61.1",
        "postcss": "^8.5.15",
        "typescript": "~6.0.3",
        "typescript-eslint": "8.62.0",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": "24"
    },
    "overrides": {
        "dompurify": "3.4.2"
    }
}
