  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3",
    "@angular/compiler": "^20.3",
    "@angular/core": "^20.3",
    "@angular/forms": "^20.3",
    "@angular/platform-browser": "^20.3",
    "@angular/router": "^20.3",
    "@fontsource-variable/lexend": "^5.2.11",
    "@primeuix/themes": "^1.2.5",
    "@tailwindcss/postcss": "^4.1.17",
    "chart.js": "^4.5.1",
    "primeicons": "^7.0.0",
    "primeng": "^20.3.0",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.1.17",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3",
    "@angular/cli": "^20.3",
    "@angular/compiler-cli": "^20.3",
    "@types/jasmine": "~5.1.13",
    "angular-eslint": "20.6.0",
    "eslint": "^9.39.1",
    "jasmine-core": "~5.12.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.46.3"
  }
