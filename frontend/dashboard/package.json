{
    "name": "@hitkeep/dashboard",
    "license": "MIT",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "transloco:optimize": "transloco-optimize dist/dashboard/browser/i18n",
        "build:tracker": "esbuild src/tracker/index.js --bundle --minify --outfile=dist/dashboard/browser/hk.js",
        "build:prod": "ng build --configuration production && npm run transloco:optimize && npm run build:tracker",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "lint": "ng lint",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^21.1.5",
        "@angular/common": "^21.1.5",
        "@angular/compiler": "^21.1.5",
        "@angular/core": "^21.1.5",
        "@angular/forms": "^21.1.5",
        "@angular/localize": "^21.1.5",
        "@angular/platform-browser": "^21.1.5",
        "@angular/router": "^21.1.5",
        "@fontsource-variable/lexend": "^5.2.11",
        "@jsverse/transloco-locale": "^8.2.1",
        "@primeuix/themes": "^2.0.3",
        "@scalar/api-reference": "^1.44.24",
        "@tailwindcss/postcss": "^4.1.18",
        "chart.js": "^4.5.1",
        "circle-flags": "^2.8.2",
        "primeicons": "^7.0.0",
        "primeng": "^21.1.1",
        "rxjs": "~7.8.2",
        "tailwindcss": "^4.1.18",
        "tailwindcss-primeui": "^0.6.1",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@angular-eslint/schematics": "^21.2.0",
        "@angular/build": "^21.1.5",
        "@angular/cli": "^21.1.5",
        "@angular/compiler-cli": "^21.1.5",
        "@jsverse/transloco": "^8.2.1",
        "@jsverse/transloco-optimize": "^8.2.1",
        "@types/jasmine": "~6.0.0",
        "@vitest/browser-playwright": "^4.0.18",
        "angular-eslint": "21.1.0",
        "baseline-browser-mapping": "^2.10.0",
        "eslint": "^9.39.2",
        "jasmine-core": "~6.0.1",
        "jsdom": "^28.1.0",
        "oxfmt": "^0.35.0",
        "postcss": "^8.5.6",
        "typescript": "~5.9.3",
        "typescript-eslint": "8.56.0",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": "24"
