  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "transloco:optimize": "transloco-optimize dist/dashboard/browser/i18n",
    "build:tracker": "esbuild src/tracker/index.js --bundle --minify --outfile=dist/dashboard/browser/hk.js",
