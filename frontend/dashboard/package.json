  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production --output-hashing=none",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint"
