{
    "name": "@hitkeep/dashboard",
    "license": "MIT",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build && npm run sync:public",
        "sync:public": "node scripts/sync-public.mjs",
        "transloco:optimize": "transloco-optimize dist/dashboard/browser/i18n",
        "build:tracker": "esbuild src/tracker/index.ts --bundle --minify --outfile=dist/dashboard/browser/hk.js",
        "build:prod": "ng build --configuration production && npm run transloco:optimize && npm run build:tracker && npm run sync:public",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "e2e": "ng e2e",
        "test:e2e": "playwright test",
        "lint": "ng lint",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^21.2.12",
        "@angular/cdk": "~21.2.10",
        "@angular/common": "^21.2.12",
        "@angular/compiler": "^21.2.12",
        "@angular/core": "^21.2.12",
        "@angular/forms": "^21.2.12",
        "@angular/platform-browser": "^21.2.12",
        "@angular/router": "^21.2.12",
        "@fontsource-variable/lexend": "^5.2.11",
        "@jsverse/transloco-locale": "^8.3.0",
        "@primeuix/themes": "^2.0.3",
        "@scalar/api-reference": "^1.55.3",
        "@tailwindcss/postcss": "^4.2.4",
        "chart.js": "^4.5.1",
        "circle-flags": "^2.8.3",
        "primeicons": "^7.0.0",
        "primeng": "^21.1.6",
        "rxjs": "~7.8.2",
        "tailwindcss": "^4.2.4",
        "tailwindcss-primeui": "^0.6.1",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@angular/build": "^21.2.10",
        "@angular/cli": "^21.2.10",
        "@angular/compiler-cli": "^21.2.12",
        "@hitkeep/ng-e2e-builder": "file:tools/ng-e2e-builder",
        "@eslint/js": "^10.0.1",
        "@jsverse/transloco": "^8.3.0",
        "@jsverse/transloco-optimize": "^8.3.0",
        "@types/jasmine": "~6.0.0",
        "@vitest/browser-playwright": "^4.1.5",
        "angular-eslint": "21.3.1",
        "baseline-browser-mapping": "^2.10.27",
        "eslint": "^10.3.0",
        "jasmine-core": "~6.2.0",
        "jsdom": "^29.1.1",
        "oxfmt": "^0.48.0",
        "postcss": "^8.5.14",
        "typescript": "~5.9.3",
        "typescript-eslint": "8.59.2",
        "vitest": "^4.1.5"
    },
    "engines": {
        "node": "24"
    }
}
