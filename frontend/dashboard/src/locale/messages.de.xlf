            <trans-unit id="loginSubtitle" datatype="html">
                <source>Sign in to your dashboard</source>
                <target>Melden Sie sich an, um Ihr Dashboard zu öffnen.</target>
            </trans-unit>
            <trans-unit id="loginEmailLabel" datatype="html">
                <source>Email Address</source>
                <target>E-Mail-Adresse</target>
            </trans-unit>
            <trans-unit id="loginEmailPlaceholder" datatype="html">
                <source>you@example.com</source>
                <target>you@example.com</target>
            </trans-unit>
            <trans-unit id="loginEmailInvalid" datatype="html">
                <source>Please enter a valid email address.</source>
                <target>Bitte geben Sie eine gültige E-Mail-Adresse ein.</target>
            </trans-unit>
            <trans-unit id="loginPasswordLabel" datatype="html">
                <source>Password</source>
                <target>Passwort</target>
            </trans-unit>
            <trans-unit id="loginForgotPassword" datatype="html">
                <source>Forgot password?</source>
                <target>Passwort vergessen?</target>
            </trans-unit>
            <trans-unit id="loginPasswordRequired" datatype="html">
                <source>Password is required.</source>
                <target>Passwort ist erforderlich.</target>
            </trans-unit>
            <trans-unit id="loginRememberMe" datatype="html">
                <source>Remember me</source>
                <target>Angemeldet bleiben</target>
            </trans-unit>
            <trans-unit id="loginSignInButton" datatype="html">
                <source>Sign In</source>
                <target>Anmelden</target>
            </trans-unit>
            <trans-unit id="loginFooterRights" datatype="html">
                <source>HitKeep. All rights reserved.</source>
                <target>HitKeep. Alle Rechte vorbehalten.</target>
            </trans-unit>
            <trans-unit id="loginErrorInvalid" datatype="html">
                <source>Invalid email or password.</source>
                <target>Ungültige E-Mail-Adresse oder Passwort.</target>
            </trans-unit>
            <trans-unit id="loginErrorUnexpected" datatype="html">
                <source>An unexpected error occurred. Please try again.</source>
                <target>Ein unerwarteter Fehler ist aufgetreten. Bitte versuchen Sie es erneut.</target>
            </trans-unit>
            <trans-unit id="preferencesSubtitle" datatype="html">
                <source>Manage your application preferences.</source>
                <target>Verwalten Sie Ihre Anwendungseinstellungen.</target>
            </trans-unit>
            <trans-unit id="preferencesLanguageHeading" datatype="html">
                <source>Language preferences</source>
                <target>Spracheinstellungen</target>
            </trans-unit>
            <trans-unit id="preferencesLanguageDescription" datatype="html">
                <source>Your browser language is used by default until you customize these settings.</source>
                <target>Die Sprache Ihres Browsers wird standardmäßig verwendet, bis Sie diese Einstellungen anpassen.</target>
            </trans-unit>
            <trans-unit id="preferencesSaved" datatype="html">
                <source>Saved</source>
                <target>Gespeichert</target>
            </trans-unit>
            <trans-unit id="preferencesSaveFailed" datatype="html">
                <source>Save failed</source>
                <target>Speichern fehlgeschlagen</target>
            </trans-unit>
            <trans-unit id="preferencesSaveChanges" datatype="html">
                <source>Save changes</source>
                <target>Änderungen speichern</target>
            </trans-unit>
            <trans-unit id="preferencesDefaultLanguageLabel" datatype="html">
                <source>Default language</source>
                <target>Standardsprache</target>
            </trans-unit>
