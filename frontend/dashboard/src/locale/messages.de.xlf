                <source>This is the primary language for the dashboard UI.</source>
                <target>Dies ist die primäre Sprache für die Dashboard-Oberfläche.</target>
            </trans-unit>
            <trans-unit id="preferencesLoadError" datatype="html">
                <source>Failed to load preferences. Please refresh and try again.</source>
                <target>Einstellungen konnten nicht geladen werden. Bitte aktualisieren Sie die Seite und versuchen Sie es erneut.</target>
            </trans-unit>
            <trans-unit id="preferencesBreadcrumb" datatype="html">
